# Qdrant (read by the Node BFF — never sent to the browser)
#
# Where you run the API decides the hostname:
#   • npm run dev ON THE HOST → use http://127.0.0.1:6333 or http://localhost:6333
#     (map must exist: docker compose exposes qdrant as host port 6333).
#   • API inside Docker Compose → use http://qdrant:6333 (service name on the compose network).
#     The `web` service in docker-compose.yml already sets that; you do not need qdrant in web/.env for the container.
#
# 127.0.0.1 vs localhost: both work for published port 6333; 127.0.0.1 avoids rare IPv6-only localhost quirks.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

RUNS_COLLECTION=regulatory_docs_runs
CHUNKS_COLLECTION=regulatory_docs

# Reviewer checkpoint (UC1-006): POST /api/runs/review merges hitlReview onto the run point in Qdrant (no extra env).

# Optional: Python agents API (proxied at /api/agents/*). Docker `web` sets http://agents:8000.
# Local dev: http://127.0.0.1:8000 when agents_api listens on the host.
AGENTS_URL=

# Optional UI login — used by the Node BFF. For Docker, `docker-compose.yml` loads this file via `env_file`
# so these values reach the container. When WEB_LOGIN_USER, WEB_LOGIN_PASSWORD, and WEB_SESSION_SECRET (≥16 chars)
# are all set, the browser must sign in; other callers need the session cookie for /api/* except /api/health and /api/auth/*.
# Use a long random WEB_SESSION_SECRET. On HTTPS behind a proxy, set WEB_COOKIE_SECURE=1.
# WEB_LOGIN_USER=demo
# WEB_LOGIN_PASSWORD=change-me
# WEB_SESSION_SECRET=replace-with-long-random-string-at-least-16-chars
# WEB_COOKIE_SECURE=0

# API port: use 9780 for `npm run dev` on the host so Docker `web` can keep 8787.
# Production / Docker image still uses 8787 unless you override.
WEB_PORT=9780
