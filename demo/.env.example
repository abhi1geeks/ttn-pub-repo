# Copy to .env and fill in. Used by docker compose (agents + n8n).

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only for temporary ASIA… keys (STS/SSO). Leave unset for AKIA IAM user keys.
# AWS_SESSION_TOKEN=

# docker compose loads this file into **n8n** and **agents** (Bedrock alert scoring, impact summary, etc.).
# Before `up.sh`, run:
#   unset AWS_SESSION_TOKEN AWS_PROFILE
# or a stale shell session token can override .env and break n8n Bedrock SigV4.

# n8n Bedrock embed node (defaults to AWS_* above if unset)
# N8N_AWS_ACCESS_KEY_ID=
# N8N_AWS_SECRET_ACCESS_KEY=

AGENTS_STUB_LLM=1
BEDROCK_CHAT_MODEL_ID=amazon.nova-pro-v1:0
