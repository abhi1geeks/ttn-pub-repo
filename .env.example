# Copy to .env and fill in (never commit .env).
# If keys were ever committed to git, rotate them in IAM first.

N8N_AWS_ACCESS_KEY_ID=
N8N_AWS_SECRET_ACCESS_KEY=
# Optional: only for temporary STS/SSO/assumed-role credentials.
# For long-term IAM access keys, leave this empty.
N8N_AWS_SESSION_TOKEN=
